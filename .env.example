# Copy to .env and fill in. In production set these in the Vercel dashboard.

# PostgreSQL connection string.
# Local dev: a Postgres running on your machine.
# Production: a hosted Postgres such as Neon (https://neon.tech) or Supabase.
DATABASE_URL="postgresql://user:password@host:5432/sparklyn"

# Auth.js secret. Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-me"

# Needed when deploying behind a proxy (Vercel sets this correctly).
AUTH_TRUST_HOST=true

# Optional Google OAuth. Leave blank to hide the Google sign-in button.
# Create credentials at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Payments (Phase 4b). Leave blank to run checkout in simulate mode.
PAYSTACK_SECRET_KEY=""
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_WEBHOOK_HASH=""

# AI (Phase 5). Leave blank to run AI features in local (no-key) mode — the
# Study Assistant and search still work using deterministic heuristics.
# Add a key from https://console.anthropic.com to enable Claude-generated answers.
ANTHROPIC_API_KEY=""
# Optional: a current Claude model id. Defaults to a fast, low-cost model.
ANTHROPIC_MODEL=""

# Optional: absolute site URL, used in /llms.txt links. Vercel sets the deploy URL,
# but set your production domain here for stable machine-readable links.
NEXT_PUBLIC_SITE_URL=""
