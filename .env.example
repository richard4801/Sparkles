# Copy to .env and fill in. In production set these in the Vercel dashboard.

# PostgreSQL connection string.
# Local dev: a Postgres running on your machine.
# Production: a hosted Postgres such as Neon (https://neon.tech) or Supabase.
DATABASE_URL="postgresql://user:password@host:5432/sparklyn"

# Auth.js secret. Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-me"

# Needed when deploying behind a proxy (Vercel sets this correctly).
AUTH_TRUST_HOST=true

# Optional Google OAuth. Leave blank to hide the Google sign-in button.
# Create credentials at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Payments (Phase 4b). Leave blank to run checkout in simulate mode.
PAYSTACK_SECRET_KEY=""
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_WEBHOOK_HASH=""

# AI (Phase 5). Leave blank to run AI features in local (no-key) mode — the
# Study Assistant and search still work using deterministic heuristics.
# Add a key from https://console.anthropic.com to enable Claude-generated answers.
ANTHROPIC_API_KEY=""
# Optional: a current Claude model id. Defaults to a fast, low-cost model.
ANTHROPIC_MODEL=""

# Absolute site URL — used in /llms.txt links AND in password-reset / verify /
# receipt email links. Set this to your production domain.
NEXT_PUBLIC_SITE_URL=""

# File downloads (Vercel Blob). On Vercel, add Blob storage to the project and
# this token is provisioned automatically. Without it, admin file uploads are
# disabled and buyers receive a placeholder PDF.
BLOB_READ_WRITE_TOKEN=""

# Transactional email (Resend). Leave blank to run in log-only mode (emails are
# printed to the server console instead of sent). Get a key at https://resend.com
RESEND_API_KEY=""
# The "from" address. Must be on a domain you've verified in Resend for production;
# defaults to Resend's onboarding sender (only delivers to your own account email).
EMAIL_FROM="Sparklyn <onboarding@resend.dev>"
