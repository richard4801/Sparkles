# Copy to .env and fill in. In production set these in the Vercel dashboard.

# PostgreSQL connection string.
# Local dev: a Postgres running on your machine.
# Production: a hosted Postgres such as Neon (https://neon.tech) or Supabase.
DATABASE_URL="postgresql://user:password@host:5432/sparklyn"

# Auth.js secret. Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-me"

# Needed when deploying behind a proxy (Vercel sets this correctly).
AUTH_TRUST_HOST=true

# Optional Google OAuth. Leave blank to hide the Google sign-in button.
# Create credentials at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
